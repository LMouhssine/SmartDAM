FLASK_SECRET_KEY=change-me
DATABASE_URL=sqlite:///smartdam.db
MAX_CONTENT_LENGTH=16777216
THUMBNAIL_MAX_SIZE=640
UPLOAD_FOLDER=uploads
LOG_LEVEL=INFO

# Local by default. Switch to true to store new files in Azure Blob Storage.
# The target container must allow public blob read access because SmartDAM stores the direct blob URL.
USE_AZURE_STORAGE=false
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=smartdam-images

# Azure AI Vision (Image Analysis)
VISION_ENDPOINT=
VISION_KEY=
VISION_LANGUAGE=fr
